# =============================================================================
# .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
.next/
out/
dist/
build/

# Environment — NEVER commit real secrets
.env
.env.local
.env.*.local
!.env.example        # the example file IS committed

# Supabase local state
supabase/.branches/
supabase/.temp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
next-env.d.ts
