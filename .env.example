# =============================================================================
# Environment Variables — copy to .env.local and fill in real values
# NEVER commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — required for all environments
# Find these in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon (public) key — safe to expose; RLS enforces all access control
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<payload>.<signature>

# Service role key — NEVER expose to the browser or commit to git
# Used only by createAdminClient() in server-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<payload>.<signature>

# JWT secret — required if you verify JWTs manually (e.g. in Edge Functions)
# Find in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# -----------------------------------------------------------------------------
# Supabase — local development overrides (supabase start)
# Uncomment these when running `supabase start` locally.
# The values below are the fixed defaults for every local Supabase instance.
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7W9oHPpGjMdJSMHqhE-IQHdSGCIwPWnVZjg
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0
# SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Direct Postgres connection — use for migrations / scripts only, not the app
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------

# Base URL of the deployed app — used for absolute redirects and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# -----------------------------------------------------------------------------
# Optional: OAuth providers (configure in supabase/config.toml too)
# -----------------------------------------------------------------------------

# Google OAuth
# SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_GOOGLE_SECRET=

# GitHub OAuth
# SUPABASE_AUTH_GITHUB_CLIENT_ID=
# SUPABASE_AUTH_GITHUB_SECRET=
